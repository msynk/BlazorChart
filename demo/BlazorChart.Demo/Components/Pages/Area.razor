@page "/area"

<PageTitle>Area &amp; Gradients</PageTitle>

<div class="page-head">
    <h1>Area &amp; Gradients</h1>
    <p>Gradient area fills, stacked areas (cumulative), and range charts that fill between two datasets.</p>
</div>

<div class="grid">
    <div class="card">
        <h3>Gradient fill</h3>
        <p class="desc">vertical gradient under a smooth line</p>
        <Chart Type="ChartType.Line" Data="@Gradient()" Options="_noLegend" />
    </div>

    <div class="card">
        <h3>Stacked area</h3>
        <p class="desc">scales.y.stacked, three cumulative series</p>
        <Chart Type="ChartType.Line" Data="@Stacked()" Options="@_stacked" />
    </div>

    <div class="card">
        <h3>Range (fill between datasets)</h3>
        <p class="desc">upper fills down to lower (FillMode.Dataset)</p>
        <Chart Type="ChartType.Line" Data="@Range()" Options="_legendBottom" />
    </div>

    <div class="card">
        <h3>Fill boundaries</h3>
        <p class="desc">origin, start (top) and end (bottom) baselines</p>
        <Chart Type="ChartType.Line" Data="@Boundaries()" Options="_legendBottom" />
    </div>

    <div class="card">
        <h3>Radial gradient</h3>
        <p class="desc">center→edge radial fill under the line</p>
        <Chart Type="ChartType.Line" Data="@RadialFill()" Options="_noLegend" />
    </div>
</div>

@code {
    private readonly ChartOptions _noLegend = new()
    {
        Plugins = new PluginOptions { Legend = new LegendOptions { Display = false } }
    };

    private readonly ChartOptions _legendBottom = new()
    {
        Plugins = new PluginOptions { Legend = new LegendOptions { Position = Position.Bottom } }
    };

    private readonly ChartOptions _stacked = new()
    {
        Plugins = new PluginOptions { Legend = new LegendOptions { Position = Position.Bottom } },
        Scales =
        {
            ["x"] = new ScaleOptions { Id = "x", Type = ScaleType.Category },
            ["y"] = new ScaleOptions { Id = "y", Type = ScaleType.Linear, Stacked = true, BeginAtZero = true }
        }
    };

    private ChartData Gradient() => new()
    {
        Labels = SampleData.Months.ToList(),
        Datasets =
        {
            new ChartDataset
            {
                Label = "Sessions",
                Data = SampleData.V(120, 190, 160, 250, 220, 300, 280),
                BorderColor = "#36a2eb",
                Tension = 0.4,
                Fill = FillMode.Origin,
                FillGradient = LinearGradient.Vertical2("rgba(54,162,235,0.55)", "rgba(54,162,235,0.02)")
            }
        }
    };

    private ChartData Stacked() => new()
    {
        Labels = SampleData.Months.ToList(),
        Datasets =
        {
            new ChartDataset { Label = "Organic", Data = SampleData.V(30, 40, 35, 50, 45, 60, 55), BorderColor = "#36a2eb", Fill = FillMode.Stack },
            new ChartDataset { Label = "Paid", Data = SampleData.V(20, 25, 30, 28, 35, 30, 40), BorderColor = "#ff6384", Fill = FillMode.Stack },
            new ChartDataset { Label = "Referral", Data = SampleData.V(10, 12, 15, 18, 14, 20, 22), BorderColor = "#4bc0c0", Fill = FillMode.Stack }
        }
    };

    private ChartData Range() => new()
    {
        Labels = SampleData.Months.ToList(),
        Datasets =
        {
            new ChartDataset { Label = "Max", Data = SampleData.V(28, 32, 30, 36, 40, 44, 42), BorderColor = "#ff9f40", Fill = FillMode.Dataset, FillTargetIndex = 1, FillColor = "rgba(255,159,64,0.18)" },
            new ChartDataset { Label = "Min", Data = SampleData.V(14, 16, 15, 20, 24, 26, 23), BorderColor = "#36a2eb", Fill = FillMode.None }
        }
    };

    private ChartData Boundaries() => new()
    {
        Labels = SampleData.Months.ToList(),
        Datasets =
        {
            new ChartDataset { Label = "Origin", Data = SampleData.V(10, -20, 30, -10, 25, -5, 15), BorderColor = "#36a2eb", Fill = FillMode.Origin, FillColor = "rgba(54,162,235,0.15)", Tension = 0.3 },
            new ChartDataset { Label = "Start (top)", Data = SampleData.V(40, 35, 45, 38, 50, 44, 55), BorderColor = "#ff6384", Fill = FillMode.Start, FillColor = "rgba(255,99,132,0.12)", Tension = 0.3 }
        }
    };

    private ChartData RadialFill() => new()
    {
        Labels = SampleData.Months.ToList(),
        Datasets =
        {
            new ChartDataset
            {
                Label = "Signal",
                Data = SampleData.V(120, 190, 160, 250, 220, 300, 280),
                BorderColor = "#9966ff",
                Tension = 0.4,
                Fill = FillMode.Origin,
                FillGradient = RadialGradient.Center2("rgba(153,102,255,0.55)", "rgba(153,102,255,0.03)")
            }
        }
    };
}
