@page "/scriptable"

<PageTitle>Scriptable options</PageTitle>

<div class="page-head">
    <h1>Scriptable options</h1>
    <p>Colors, point radius and point styles computed per data element from a context &mdash; the defining Chart.js feature, now in C#.</p>
</div>

<div class="grid">
    <div class="card">
        <h3>Color by sign</h3>
        <p class="desc">bars turn red when the value is negative</p>
        <Chart Type="ChartType.Bar" Data="@BySign()" Options="_noLegend" />
    </div>

    <div class="card">
        <h3>Color by threshold</h3>
        <p class="desc">points above 75 are highlighted</p>
        <Chart Type="ChartType.Line" Data="@ByThreshold()" Options="_noLegend" />
    </div>

    <div class="card">
        <h3>Radius by value</h3>
        <p class="desc">point radius scales with the value</p>
        <Chart Type="ChartType.Line" Data="@RadiusByValue()" Options="_noLegend" />
    </div>

    <div class="card">
        <h3>Style by parity</h3>
        <p class="desc">alternating point styles + active highlight</p>
        <Chart Type="ChartType.Line" Data="@StyleByParity()" Options="_noLegend" />
    </div>
</div>

@code {
    private readonly ChartOptions _noLegend = new()
    {
        Plugins = new PluginOptions { Legend = new LegendOptions { Display = false } }
    };

    private ChartData BySign() => new()
    {
        Labels = SampleData.Months.ToList(),
        Datasets =
        {
            new ChartDataset
            {
                Label = "Net change",
                Data = SampleData.V(12, -8, 22, -4, 18, -15, 9),
                BorderRadius = 4,
                BackgroundColorFn = ctx => (ctx.Value ?? 0) < 0 ? "#ff6384" : "#4bc0c0"
            }
        }
    };

    private ChartData ByThreshold() => new()
    {
        Labels = SampleData.Months.ToList(),
        Datasets =
        {
            new ChartDataset
            {
                Label = "Score",
                Data = SampleData.V(60, 72, 80, 68, 91, 55, 84),
                BorderColor = "#36a2eb",
                Tension = 0.3,
                PointRadius = 5,
                PointBackgroundColorFn = ctx => (ctx.Value ?? 0) >= 75 ? "#ff9f40" : "#36a2eb",
                PointRadiusFn = ctx => (ctx.Value ?? 0) >= 75 ? 7 : 4
            }
        }
    };

    private ChartData RadiusByValue() => new()
    {
        Labels = SampleData.Months.ToList(),
        Datasets =
        {
            new ChartDataset
            {
                Label = "Volume",
                Data = SampleData.V(10, 35, 22, 60, 48, 80, 30),
                BorderColor = "#9966ff",
                Tension = 0.4,
                PointBackgroundColor = "#9966ff",
                PointRadiusFn = ctx => 3 + (ctx.Value ?? 0) / 12
            }
        }
    };

    private ChartData StyleByParity() => new()
    {
        Labels = SampleData.Months.ToList(),
        Datasets =
        {
            new ChartDataset
            {
                Label = "Signal",
                Data = SampleData.V(40, 55, 48, 70, 62, 80, 72),
                BorderColor = "#2ecc71",
                Tension = 0.3,
                PointRadius = 5,
                PointBackgroundColor = "#2ecc71",
                PointStyleFn = ctx => ctx.DataIndex % 2 == 0 ? PointStyle.RectRot : PointStyle.Triangle
            }
        }
    };
}
