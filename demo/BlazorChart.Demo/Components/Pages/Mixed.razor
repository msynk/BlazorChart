@page "/mixed"

<PageTitle>Mixed charts</PageTitle>

<div class="page-head">
    <h1>Mixed charts</h1>
    <p>Combine bar and line datasets on the same chart, optionally with a second y axis. Each dataset can set its own <code>Type</code>.</p>
</div>

<div class="grid">
    <div class="card">
        <h3>Bar + line</h3>
        <p class="desc">line drawn on top of bars</p>
        <Chart Type="ChartType.Bar" Data="@BarLine()" Options="_bottom" />
    </div>

    <div class="card">
        <h3>Dual axis</h3>
        <p class="desc">revenue (left) vs. margin % (right)</p>
        <Chart Type="ChartType.Bar" Data="@DualAxis()" Options="@_dual" />
    </div>
</div>

@code {
    private readonly ChartOptions _bottom = new()
    {
        Plugins = new PluginOptions { Legend = new LegendOptions { Position = Position.Bottom } }
    };

    private readonly ChartOptions _dual = new()
    {
        Plugins = new PluginOptions { Legend = new LegendOptions { Position = Position.Bottom } },
        Scales =
        {
            ["y"] = new ScaleOptions { Id = "y", Type = ScaleType.Linear, Position = Position.Left, BeginAtZero = true,
                Title = new ScaleTitleOptions { Display = true, Text = "Revenue ($k)" } },
            ["y2"] = new ScaleOptions { Id = "y2", Type = ScaleType.Linear, Position = Position.Right, BeginAtZero = true,
                Title = new ScaleTitleOptions { Display = true, Text = "Margin %" },
                Grid = new GridOptions { DrawOnChartArea = false } }
        }
    };

    private ChartData BarLine() => new()
    {
        Labels = SampleData.Months.ToList(),
        Datasets =
        {
            new ChartDataset { Type = ChartType.Bar, Label = "Units", Data = SampleData.V(40, 55, 48, 70, 62, 80, 75), BackgroundColor = "#36a2eb" },
            new ChartDataset { Type = ChartType.Line, Label = "Trend", Data = SampleData.V(38, 50, 52, 64, 68, 76, 80), BorderColor = "#ff6384", Tension = 0.4 }
        }
    };

    private ChartData DualAxis() => new()
    {
        Labels = SampleData.Months.ToList(),
        Datasets =
        {
            new ChartDataset { Type = ChartType.Bar, Label = "Revenue", YAxisID = "y", Data = SampleData.V(120, 150, 130, 180, 165, 210, 195), BackgroundColor = "#36a2eb" },
            new ChartDataset { Type = ChartType.Line, Label = "Margin", YAxisID = "y2", Data = SampleData.V(18, 22, 20, 26, 24, 30, 28), BorderColor = "#ff9f40", Tension = 0.3 }
        }
    };
}
