@page "/legend"

<PageTitle>Legend</PageTitle>

<div class="page-head">
    <h1>Legend</h1>
    <p>Position, alignment, a legend title, point-style markers and reversed order. Click any item to toggle its dataset &mdash; the chart recomputes instantly.</p>
</div>

<div class="controls">
    <label>
        Position
        <select @bind="_position">
            <option value="@Position.Top">Top</option>
            <option value="@Position.Bottom">Bottom</option>
            <option value="@Position.Left">Left</option>
            <option value="@Position.Right">Right</option>
        </select>
    </label>
    <label>
        Align
        <select @bind="_align">
            <option value="@Align.Start">Start</option>
            <option value="@Align.Center">Center</option>
            <option value="@Align.End">End</option>
        </select>
    </label>
    <label><input type="checkbox" @bind="_usePointStyle" /> Point style</label>
    <label><input type="checkbox" @bind="_reverse" /> Reverse</label>
</div>

<div class="card" style="margin-bottom:22px">
    <Chart Type="ChartType.Line" Data="@MultiSeries()" Options="@Live()" />
</div>

<div class="grid">
    <div class="card">
        <h3>Legend title</h3>
        <p class="desc">a heading above the items</p>
        <Chart Type="ChartType.Bar" Data="SampleData.Revenue()" Options="@_titled" />
    </div>

    <div class="card">
        <h3>Point-style markers</h3>
        <p class="desc">usePointStyle uses each dataset's marker</p>
        <Chart Type="ChartType.Line" Data="@Markers()" Options="@_pointStyle" />
    </div>
</div>

@code {
    private Position _position = Position.Top;
    private Align _align = Align.Center;
    private bool _usePointStyle;
    private bool _reverse;

    private ChartOptions Live() => new()
    {
        Plugins = new PluginOptions
        {
            Legend = new LegendOptions
            {
                Position = _position, Align = _align, Reverse = _reverse,
                Labels = new LegendLabelOptions { UsePointStyle = _usePointStyle }
            }
        }
    };

    private readonly ChartOptions _titled = new()
    {
        Plugins = new PluginOptions
        {
            Legend = new LegendOptions { Position = Position.Bottom, Title = "Product lines" }
        }
    };

    private readonly ChartOptions _pointStyle = new()
    {
        Plugins = new PluginOptions
        {
            Legend = new LegendOptions { Position = Position.Bottom, Labels = new LegendLabelOptions { UsePointStyle = true } }
        }
    };

    private ChartData MultiSeries() => new()
    {
        Labels = SampleData.Months.ToList(),
        Datasets =
        {
            new ChartDataset { Label = "Alpha", Data = SampleData.V(65, 59, 80, 81, 56, 55, 72), BorderColor = "#36a2eb", BackgroundColor = "#36a2eb", Tension = 0.3 },
            new ChartDataset { Label = "Beta", Data = SampleData.V(28, 48, 40, 60, 86, 92, 78), BorderColor = "#ff6384", BackgroundColor = "#ff6384", Tension = 0.3 },
            new ChartDataset { Label = "Gamma", Data = SampleData.V(40, 35, 60, 45, 70, 50, 65), BorderColor = "#4bc0c0", BackgroundColor = "#4bc0c0", Tension = 0.3 }
        }
    };

    private ChartData Markers() => new()
    {
        Labels = SampleData.Months.ToList(),
        Datasets =
        {
            new ChartDataset { Label = "Stars", Data = SampleData.V(20, 35, 28, 45, 38, 52, 44), BorderColor = "#ff9f40", PointBackgroundColor = "#ff9f40", PointStyle = PointStyle.Star, PointRadius = 6, Tension = 0.3 },
            new ChartDataset { Label = "Triangles", Data = SampleData.V(12, 22, 18, 30, 26, 38, 32), BorderColor = "#9966ff", PointBackgroundColor = "#9966ff", PointStyle = PointStyle.Triangle, PointRadius = 6, Tension = 0.3 }
        }
    };
}
