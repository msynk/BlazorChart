@page "/tooltips"

<PageTitle>Tooltips</PageTitle>

<div class="page-head">
    <h1>Tooltips</h1>
    <p>The full Chart.js callback set &mdash; custom title, per-line labels, color swatches, after-body notes and footers &mdash; plus index mode and styling.</p>
</div>

<div class="grid">
    <div class="card">
        <h3>Title &amp; footer callbacks</h3>
        <p class="desc">hover a group: custom title + summed footer</p>
        <Chart Type="ChartType.Bar" Data="SampleData.Revenue()" Options="@_footer" />
    </div>

    <div class="card">
        <h3>Currency labels</h3>
        <p class="desc">label callback formats each row as currency</p>
        <Chart Type="ChartType.Line" Data="@TwoSeries()" Options="@_currency" />
    </div>

    <div class="card">
        <h3>After-body note</h3>
        <p class="desc">extra context appended below the values</p>
        <Chart Type="ChartType.Line" Data="@TwoSeries()" Options="@_afterBody" />
    </div>

    <div class="card">
        <h3>Styled box</h3>
        <p class="desc">light theme, border, centered text</p>
        <Chart Type="ChartType.Bar" Data="SampleData.Revenue()" Options="@_styled" />
    </div>

    <div class="card">
        <h3>Point-style swatches</h3>
        <p class="desc">usePointStyle draws the marker in the tooltip</p>
        <Chart Type="ChartType.Line" Data="@Markers()" Options="@_pointStyle" />
    </div>
</div>

@code {
    private readonly ChartOptions _footer = new()
    {
        Plugins = new PluginOptions
        {
            Legend = new LegendOptions { Position = Position.Bottom },
            Tooltip = new TooltipOptions
            {
                Mode = InteractionMode.Index,
                Callbacks = new TooltipCallbacks
                {
                    Title = items => items.Count > 0 ? $"Month: {items[0].Label}" : null,
                    Footer = items => $"Total: {items.Sum(i => i.Value):N0}"
                }
            }
        }
    };

    private readonly ChartOptions _currency = new()
    {
        Plugins = new PluginOptions
        {
            Legend = new LegendOptions { Position = Position.Bottom },
            Tooltip = new TooltipOptions
            {
                Mode = InteractionMode.Index,
                Callbacks = new TooltipCallbacks
                {
                    Label = item => $"{item.DatasetLabel}: {item.Value:C0}"
                }
            }
        }
    };

    private readonly ChartOptions _afterBody = new()
    {
        Plugins = new PluginOptions
        {
            Legend = new LegendOptions { Position = Position.Bottom },
            Tooltip = new TooltipOptions
            {
                Mode = InteractionMode.Index,
                Callbacks = new TooltipCallbacks
                {
                    AfterBody = items =>
                    {
                        if (items.Count < 2) return null;
                        double diff = items[0].Value - items[1].Value;
                        return $"Margin: {diff:N0}";
                    }
                }
            }
        }
    };

    private readonly ChartOptions _styled = new()
    {
        Plugins = new PluginOptions
        {
            Legend = new LegendOptions { Position = Position.Bottom },
            Tooltip = new TooltipOptions
            {
                Mode = InteractionMode.Index,
                BackgroundColor = "#ffffff",
                TitleColor = "#1f2733",
                BodyColor = "#3a4452",
                FooterColor = "#1f2733",
                BorderColor = "#e0e4ea",
                BorderWidth = 1,
                TitleAlign = Align.Center,
                Callbacks = new TooltipCallbacks
                {
                    Footer = items => $"{items.Count} series"
                }
            }
        }
    };

    private ChartData TwoSeries() => new()
    {
        Labels = { "Q1", "Q2", "Q3", "Q4" },
        Datasets =
        {
            new ChartDataset { Label = "Revenue", Data = SampleData.V(1200, 1500, 1700, 2100), BorderColor = "#36a2eb", BackgroundColor = "#36a2eb", Tension = 0.4 },
            new ChartDataset { Label = "Costs", Data = SampleData.V(800, 950, 1100, 1300), BorderColor = "#ff6384", BackgroundColor = "#ff6384", Tension = 0.4 }
        }
    };

    private readonly ChartOptions _pointStyle = new()
    {
        Plugins = new PluginOptions
        {
            Legend = new LegendOptions { Position = Position.Bottom, Labels = new LegendLabelOptions { UsePointStyle = true } },
            Tooltip = new TooltipOptions { Mode = InteractionMode.Index, UsePointStyle = true }
        }
    };

    private ChartData Markers() => new()
    {
        Labels = SampleData.Months.ToList(),
        Datasets =
        {
            new ChartDataset { Label = "Triangles", Data = SampleData.V(20, 35, 28, 45, 38, 52, 44),
                BorderColor = "#4bc0c0", PointBackgroundColor = "#4bc0c0", PointStyle = PointStyle.Triangle, PointRadius = 5, Tension = 0.3 },
            new ChartDataset { Label = "Diamonds", Data = SampleData.V(12, 22, 18, 30, 26, 38, 32),
                BorderColor = "#ff9f40", PointBackgroundColor = "#ff9f40", PointStyle = PointStyle.RectRot, PointRadius = 5, Tension = 0.3 }
        }
    };
}
