@page "/time"

<PageTitle>Time axis</PageTitle>

<div class="page-head">
    <h1>Time axis</h1>
    <p>
        A date/time scale automatically picks a sensible unit (hour, day, week, month, year) for the
        data range and formats tick labels accordingly. Points carry their x as a date.
    </p>
</div>

<div class="grid">
    <div class="card">
        <h3>Daily series (auto unit)</h3>
        <p class="desc">60 days &rarr; weekly ticks</p>
        <Chart Type="ChartType.Line" Data="SampleData.TimeSeries()" Options="@_time" />
    </div>

    <div class="card">
        <h3>Forced month unit + custom format</h3>
        <p class="desc">TimeUnit.Month, custom formatter</p>
        <Chart Type="ChartType.Line" Data="SampleData.TimeSeries()" Options="@_month" />
    </div>
</div>

@code {
    private readonly ChartOptions _time = new()
    {
        Plugins = new PluginOptions { Legend = new LegendOptions { Display = false } },
        Scales =
        {
            ["x"] = new ScaleOptions { Id = "x", Type = ScaleType.Time },
            ["y"] = new ScaleOptions { Id = "y", Type = ScaleType.Linear }
        }
    };

    private readonly ChartOptions _month = new()
    {
        Plugins = new PluginOptions { Legend = new LegendOptions { Display = false } },
        Scales =
        {
            ["x"] = new ScaleOptions
            {
                Id = "x", Type = ScaleType.Time, TimeUnit = TimeUnit.Week,
                TimeFormat = d => d.ToString("d MMM")
            },
            ["y"] = new ScaleOptions { Id = "y", Type = ScaleType.Linear }
        }
    };
}
