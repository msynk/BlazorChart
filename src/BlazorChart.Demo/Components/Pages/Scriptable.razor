@page "/scriptable"

<PageTitle>Scriptable options</PageTitle>

<div class="page-head">
    <h1>Scriptable options</h1>
    <p>Colors, point radius and point styles computed per data element from a context &mdash; the defining Chart.js feature, now in C#.</p>
</div>

<div class="grid">
    <div class="card">
        <h3>Color by sign</h3>
        <p class="desc">bars turn red when the value is negative</p>
        <BlazorChart Type="BlazorChartType.Bar" Data="@BySign()" Options="_noLegend" />
        <CodeBlock Code="@BySignSnippet" />
    </div>

    <div class="card">
        <h3>Color by threshold</h3>
        <p class="desc">points above 75 are highlighted</p>
        <BlazorChart Type="BlazorChartType.Line" Data="@ByThreshold()" Options="_noLegend" />
        <CodeBlock Code="@ByThresholdSnippet" />
    </div>

    <div class="card">
        <h3>Radius by value</h3>
        <p class="desc">point radius scales with the value</p>
        <BlazorChart Type="BlazorChartType.Line" Data="@RadiusByValue()" Options="_noLegend" />
        <CodeBlock Code="@RadiusByValueSnippet" />
    </div>

    <div class="card">
        <h3>Style by parity</h3>
        <p class="desc">alternating point styles + active highlight</p>
        <BlazorChart Type="BlazorChartType.Line" Data="@StyleByParity()" Options="_noLegend" />
        <CodeBlock Code="@StyleByparitySnippet" />
    </div>
</div>

@code {
    private const string BySignSnippet = """
        <BlazorChart Type="BlazorChartType.Bar" Data="BySign()" Options="_noLegend" />

        @code {
            private readonly BlazorChartOptions _noLegend = new()
            {
                Plugins = new BlazorChartPluginOptions { Legend = new BlazorChartLegendOptions { Display = false } }
            };

            private BlazorChartData BySign() => new()
            {
                Labels = { "Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul" },
                Datasets =
                {
                    new BlazorChartDataset
                    {
                        Label = "Net change",
                        Data = new() { 12, -8, 22, -4, 18, -15, 9 },
                        BorderRadius = 4,
                        // Scriptable: receives a context per element
                        BackgroundColorFn = ctx => (ctx.Value ?? 0) < 0 ? "#ff6384" : "#4bc0c0"
                    }
                }
            };
        }
        """;

    private const string ByThresholdSnippet = """
        <BlazorChart Type="BlazorChartType.Line" Data="ByThreshold()" Options="_noLegend" />

        @code {
            private readonly BlazorChartOptions _noLegend = new()
            {
                Plugins = new BlazorChartPluginOptions { Legend = new BlazorChartLegendOptions { Display = false } }
            };

            private BlazorChartData ByThreshold() => new()
            {
                Labels = { "Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul" },
                Datasets =
                {
                    new BlazorChartDataset
                    {
                        Label = "Score",
                        Data = new() { 60, 72, 80, 68, 91, 55, 84 },
                        BorderColor = "#36a2eb",
                        Tension = 0.3,
                        PointRadius = 5,
                        PointBackgroundColorFn = ctx => (ctx.Value ?? 0) >= 75 ? "#ff9f40" : "#36a2eb",
                        PointRadiusFn = ctx => (ctx.Value ?? 0) >= 75 ? 7 : 4
                    }
                }
            };
        }
        """;

    private const string RadiusByValueSnippet = """
        <BlazorChart Type="BlazorChartType.Line" Data="RadiusByValue()" Options="_noLegend" />

        @code {
            private readonly BlazorChartOptions _noLegend = new()
            {
                Plugins = new BlazorChartPluginOptions { Legend = new BlazorChartLegendOptions { Display = false } }
            };

            private BlazorChartData RadiusByValue() => new()
            {
                Labels = { "Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul" },
                Datasets =
                {
                    new BlazorChartDataset
                    {
                        Label = "Volume",
                        Data = new() { 10, 35, 22, 60, 48, 80, 30 },
                        BorderColor = "#9966ff",
                        Tension = 0.4,
                        PointBackgroundColor = "#9966ff",
                        PointRadiusFn = ctx => 3 + (ctx.Value ?? 0) / 12
                    }
                }
            };
        }
        """;

    private const string StyleByparitySnippet = """
        <BlazorChart Type="BlazorChartType.Line" Data="StyleByParity()" Options="_noLegend" />

        @code {
            private readonly BlazorChartOptions _noLegend = new()
            {
                Plugins = new BlazorChartPluginOptions { Legend = new BlazorChartLegendOptions { Display = false } }
            };

            private BlazorChartData StyleByParity() => new()
            {
                Labels = { "Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul" },
                Datasets =
                {
                    new BlazorChartDataset
                    {
                        Label = "Signal",
                        Data = new() { 40, 55, 48, 70, 62, 80, 72 },
                        BorderColor = "#2ecc71",
                        Tension = 0.3,
                        PointRadius = 5,
                        PointBackgroundColor = "#2ecc71",
                        PointStyleFn = ctx => ctx.DataIndex % 2 == 0 ? BlazorChartPointStyle.RectRot : BlazorChartPointStyle.Triangle
                    }
                }
            };
        }
        """;

    private readonly BlazorChartOptions _noLegend = new()
    {
        Plugins = new BlazorChartPluginOptions { Legend = new BlazorChartLegendOptions { Display = false } }
    };

    private BlazorChartData BySign() => new()
    {
        Labels = SampleData.Months.ToList(),
        Datasets =
        {
            new BlazorChartDataset
            {
                Label = "Net change",
                Data = SampleData.V(12, -8, 22, -4, 18, -15, 9),
                BorderRadius = 4,
                BackgroundColorFn = ctx => (ctx.Value ?? 0) < 0 ? "#ff6384" : "#4bc0c0"
            }
        }
    };

    private BlazorChartData ByThreshold() => new()
    {
        Labels = SampleData.Months.ToList(),
        Datasets =
        {
            new BlazorChartDataset
            {
                Label = "Score",
                Data = SampleData.V(60, 72, 80, 68, 91, 55, 84),
                BorderColor = "#36a2eb",
                Tension = 0.3,
                PointRadius = 5,
                PointBackgroundColorFn = ctx => (ctx.Value ?? 0) >= 75 ? "#ff9f40" : "#36a2eb",
                PointRadiusFn = ctx => (ctx.Value ?? 0) >= 75 ? 7 : 4
            }
        }
    };

    private BlazorChartData RadiusByValue() => new()
    {
        Labels = SampleData.Months.ToList(),
        Datasets =
        {
            new BlazorChartDataset
            {
                Label = "Volume",
                Data = SampleData.V(10, 35, 22, 60, 48, 80, 30),
                BorderColor = "#9966ff",
                Tension = 0.4,
                PointBackgroundColor = "#9966ff",
                PointRadiusFn = ctx => 3 + (ctx.Value ?? 0) / 12
            }
        }
    };

    private BlazorChartData StyleByParity() => new()
    {
        Labels = SampleData.Months.ToList(),
        Datasets =
        {
            new BlazorChartDataset
            {
                Label = "Signal",
                Data = SampleData.V(40, 55, 48, 70, 62, 80, 72),
                BorderColor = "#2ecc71",
                Tension = 0.3,
                PointRadius = 5,
                PointBackgroundColor = "#2ecc71",
                PointStyleFn = ctx => ctx.DataIndex % 2 == 0 ? BlazorChartPointStyle.RectRot : BlazorChartPointStyle.Triangle
            }
        }
    };
}
