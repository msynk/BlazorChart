@page "/pie"

<PageTitle>Pie &amp; Doughnut</PageTitle>

<div class="page-head">
    <h1>Pie &amp; Doughnut</h1>
    <p>Proportional slices with click-to-toggle legend, adjustable cutout, rotation and partial circumference. Hover a slice to see its share.</p>
</div>

<div class="grid">
    <div class="card">
        <h3>Pie</h3>
        <p class="desc">click a legend label to hide a slice</p>
        <BlazorChart Type="BlazorChartType.Pie" Data="SampleData.Traffic()" Options="_right" />
    </div>

    <div class="card">
        <h3>Doughnut</h3>
        <p class="desc">cutout 60%</p>
        <BlazorChart Type="BlazorChartType.Doughnut" Data="SampleData.Traffic()" Options="@_doughnut" />
    </div>

    <div class="card">
        <h3>Half doughnut (gauge)</h3>
        <p class="desc">circumference 180°, rotation -90°</p>
        <BlazorChart Type="BlazorChartType.Doughnut" Data="@Gauge()" Options="@_gauge" />
    </div>

    <div class="card">
        <h3>Multi-ring</h3>
        <p class="desc">two datasets as concentric rings</p>
        <BlazorChart Type="BlazorChartType.Doughnut" Data="@MultiRing()" Options="_right" />
    </div>

    <div class="card">
        <h3>Center text (KPI)</h3>
        <p class="desc">BlazorChartCenterTextPlugin draws a total in the cutout</p>
        <BlazorChart Type="BlazorChartType.Doughnut" Data="SampleData.Traffic()" Options="@_centerText" />
    </div>
</div>

@code {
    private readonly BlazorChartOptions _right = new()
    {
        Plugins = new BlazorChartPluginOptions { Legend = new BlazorChartLegendOptions { Position = BlazorChartPosition.Right } }
    };

    private readonly BlazorChartOptions _centerText = new()
    {
        CutoutPercentage = 68,
        Plugins = new BlazorChartPluginOptions
        {
            Legend = new BlazorChartLegendOptions { Position = BlazorChartPosition.Right },
            Custom = { new BlazorChartCenterTextPlugin("1,340", "sessions") }
        }
    };

    private readonly BlazorChartOptions _doughnut = new()
    {
        CutoutPercentage = 60,
        Plugins = new BlazorChartPluginOptions { Legend = new BlazorChartLegendOptions { Position = BlazorChartPosition.Right } }
    };

    private readonly BlazorChartOptions _gauge = new()
    {
        CutoutPercentage = 65,
        CircumferenceDegrees = 180,
        RotationDegrees = -90,
        Plugins = new BlazorChartPluginOptions { Legend = new BlazorChartLegendOptions { Position = BlazorChartPosition.Bottom } }
    };

    private BlazorChartData Gauge() => new()
    {
        Labels = { "Used", "Free" },
        Datasets =
        {
            new BlazorChartDataset { Data = SampleData.V(68, 32), BackgroundColors = new() { "#ff6384", "#e6e9ef" } }
        }
    };

    private BlazorChartData MultiRing() => new()
    {
        Labels = { "Mobile", "Desktop", "Tablet" },
        Datasets =
        {
            new BlazorChartDataset { Label = "2025", Data = SampleData.V(55, 35, 10) },
            new BlazorChartDataset { Label = "2026", Data = SampleData.V(62, 28, 10) }
        }
    };
}
