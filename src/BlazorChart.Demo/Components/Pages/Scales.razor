@page "/scales"

<PageTitle>Scales</PageTitle>

<div class="page-head">
    <h1>Scales</h1>
    <p>Fixed min/max, suggested bounds, explicit step size, logarithmic and reversed axes &mdash; the cartesian scale options from Chart.js, mapped 1:1.</p>
</div>

<div class="grid">
    <div class="card">
        <h3>Fixed min / max</h3>
        <p class="desc">y locked to 0–100</p>
        <BlazorChart Type="BlazorChartType.Line" Data="@Series()" Options="@_minMax" />
    </div>

    <div class="card">
        <h3>Suggested min / max</h3>
        <p class="desc">hints that expand (not clamp) the range</p>
        <BlazorChart Type="BlazorChartType.Line" Data="@Series()" Options="@_suggested" />
    </div>

    <div class="card">
        <h3>Explicit step size</h3>
        <p class="desc">ticks every 25 units</p>
        <BlazorChart Type="BlazorChartType.Bar" Data="@Series()" Options="@_step" />
    </div>

    <div class="card">
        <h3>Logarithmic</h3>
        <p class="desc">decade ticks + minor gridlines</p>
        <BlazorChart Type="BlazorChartType.Line" Data="@LogData()" Options="@_log" />
    </div>

    <div class="card">
        <h3>Reversed Y axis</h3>
        <p class="desc">rankings: lower is better</p>
        <BlazorChart Type="BlazorChartType.Line" Data="@Rank()" Options="@_reverse" />
    </div>

    <div class="card">
        <h3>Grace (padding)</h3>
        <p class="desc">10% headroom above & below the data</p>
        <BlazorChart Type="BlazorChartType.Line" Data="@Series()" Options="@_grace" />
    </div>
</div>

@code {
    private readonly BlazorChartOptions _minMax = new()
    {
        Plugins = new BlazorChartPluginOptions { Legend = new BlazorChartLegendOptions { Display = false } },
        Scales = { ["y"] = new BlazorChartScaleOptions { Id = "y", Type = BlazorChartScaleType.Linear, Min = 0, Max = 100 } }
    };

    private readonly BlazorChartOptions _suggested = new()
    {
        Plugins = new BlazorChartPluginOptions { Legend = new BlazorChartLegendOptions { Display = false } },
        Scales = { ["y"] = new BlazorChartScaleOptions { Id = "y", Type = BlazorChartScaleType.Linear, SuggestedMin = 0, SuggestedMax = 100 } }
    };

    private readonly BlazorChartOptions _step = new()
    {
        Plugins = new BlazorChartPluginOptions { Legend = new BlazorChartLegendOptions { Display = false } },
        Scales = { ["y"] = new BlazorChartScaleOptions { Id = "y", Type = BlazorChartScaleType.Linear, BeginAtZero = true, Ticks = new BlazorChartTickOptions { StepSize = 25 } } }
    };

    private readonly BlazorChartOptions _log = new()
    {
        Plugins = new BlazorChartPluginOptions { Legend = new BlazorChartLegendOptions { Display = false } },
        Scales = { ["y"] = new BlazorChartScaleOptions { Id = "y", Type = BlazorChartScaleType.Logarithmic } }
    };

    private readonly BlazorChartOptions _reverse = new()
    {
        Plugins = new BlazorChartPluginOptions { Legend = new BlazorChartLegendOptions { Display = false } },
        Scales = { ["y"] = new BlazorChartScaleOptions { Id = "y", Type = BlazorChartScaleType.Linear, Reverse = true, Min = 1, Max = 10 } }
    };

    private readonly BlazorChartOptions _grace = new()
    {
        Plugins = new BlazorChartPluginOptions { Legend = new BlazorChartLegendOptions { Display = false } },
        Scales = { ["y"] = new BlazorChartScaleOptions { Id = "y", Type = BlazorChartScaleType.Linear, Grace = 0.1 } }
    };

    private BlazorChartData Series() => new()
    {
        Labels = SampleData.Months.ToList(),
        Datasets = { new BlazorChartDataset { Label = "Value", Data = SampleData.V(35, 52, 48, 70, 60, 78, 66), BorderColor = "#36a2eb", BackgroundColor = "#36a2eb", Tension = 0.3 } }
    };

    private BlazorChartData Rank() => new()
    {
        Labels = SampleData.Months.ToList(),
        Datasets = { new BlazorChartDataset { Label = "Rank", Data = SampleData.V(8, 6, 7, 3, 4, 2, 1), BorderColor = "#9966ff", BackgroundColor = "#9966ff", Tension = 0.3 } }
    };

    private BlazorChartData LogData() => new()
    {
        Labels = SampleData.Months.ToList(),
        Datasets = { new BlazorChartDataset { Label = "Growth", Data = SampleData.V(1, 10, 100, 1000, 5000, 20000, 80000), BorderColor = "#ff6384", BackgroundColor = "#ff6384", Tension = 0.2 } }
    };
}
