@page "/features"

<PageTitle>Customization</PageTitle>

<div class="page-head">
    <h1>Customization</h1>
    <p>Titles &amp; subtitles, axis titles, tick formatting callbacks, custom tooltip text, data labels, grid styling and click events.</p>
</div>

<div class="grid">
    <div class="card">
        <h3>Title, subtitle &amp; axis titles</h3>
        <p class="desc">currency tick formatting via callback</p>
        <BlazorChart Type="BlazorChartType.Line" Data="@Revenue()" Options="@_titled" />
    </div>

    <div class="card">
        <h3>Data labels</h3>
        <p class="desc">values drawn above each bar</p>
        <BlazorChart Type="BlazorChartType.Bar" Data="@Simple()" Options="@_dataLabels" />
    </div>

    <div class="card">
        <h3>Custom grid &amp; ticks</h3>
        <p class="desc">dashed grid, stepSize, suffix</p>
        <BlazorChart Type="BlazorChartType.Line" Data="@Simple()" Options="@_grid" />
    </div>

    <div class="card">
        <h3>Click events</h3>
        <p class="desc">click any bar</p>
        <BlazorChart Type="BlazorChartType.Bar" Data="@Simple()" OnElementClick="OnClick" />
        <div class="click-log">@_log</div>
    </div>

    <div class="card">
        <h3>Custom tooltip template</h3>
        <p class="desc">index mode + your own Razor markup</p>
        <BlazorChart Type="BlazorChartType.Line" Data="@TwoSeries()" Options="@_indexTooltip">
            <TooltipTemplate Context="ctx">
                <div style="font-weight:600;margin-bottom:4px">@ctx.Title</div>
                @foreach (var p in ctx.Points)
                {
                    <div style="display:flex;align-items:center;gap:6px">
                        <span style="width:10px;height:10px;border-radius:50%;background:@p.Color;display:inline-block"></span>
                        <span>@p.Label</span>
                        <strong style="margin-left:auto">@p.Value.ToString("C0")</strong>
                    </div>
                }
            </TooltipTemplate>
        </BlazorChart>
    </div>

    <div class="card">
        <h3>Multi-line &amp; bottom title</h3>
        <p class="desc">title with a line break, positioned below</p>
        <BlazorChart Type="BlazorChartType.Bar" Data="@Simple()" Options="@_bottomTitle" />
    </div>
</div>

@code {
    private string _log = "No element clicked yet.";

    private void OnClick((int DatasetIndex, int DataIndex) e)
        => _log = $"Clicked dataset {e.DatasetIndex}, index {e.DataIndex}.";

    private readonly BlazorChartOptions _titled = new()
    {
        Plugins = new BlazorChartPluginOptions
        {
            Title = new BlazorChartTitleOptions { Display = true, Text = "Quarterly Revenue" },
            Subtitle = new BlazorChartTitleOptions { Display = true, Text = "in thousands of USD" },
            Legend = new BlazorChartLegendOptions { Position = BlazorChartPosition.Bottom },
            Tooltip = new BlazorChartTooltipOptions { LabelFormatter = (label, v) => $"{label}: ${v:N0}k" }
        },
        Scales =
        {
            ["y"] = new BlazorChartScaleOptions
            {
                Id = "y", Type = BlazorChartScaleType.Linear, BeginAtZero = true,
                Title = new BlazorChartScaleTitleOptions { Display = true, Text = "Revenue" },
                Ticks = new BlazorChartTickOptions { Prefix = "$", Suffix = "k" }
            }
        }
    };

    private readonly BlazorChartOptions _dataLabels = new()
    {
        Plugins = new BlazorChartPluginOptions
        {
            Legend = new BlazorChartLegendOptions { Display = false },
            DataLabels = new BlazorChartDataLabelOptions { Display = true, Color = "#333" }
        }
    };

    private readonly BlazorChartOptions _grid = new()
    {
        Plugins = new BlazorChartPluginOptions { Legend = new BlazorChartLegendOptions { Display = false } },
        Scales =
        {
            ["y"] = new BlazorChartScaleOptions
            {
                Id = "y", Type = BlazorChartScaleType.Linear, BeginAtZero = true,
                Ticks = new BlazorChartTickOptions { StepSize = 20, Suffix = "%" },
                Grid = new BlazorChartGridOptions { BorderDash = new() { 4, 4 }, Color = "rgba(54,162,235,0.18)" }
            }
        }
    };

    private BlazorChartData Revenue() => new()
    {
        Labels = { "Q1", "Q2", "Q3", "Q4" },
        Datasets =
        {
            new BlazorChartDataset { Label = "2026", Data = SampleData.V(120, 150, 170, 210), BorderColor = "#36a2eb", Tension = 0.4, Fill = BlazorChartFillMode.Origin }
        }
    };

    private BlazorChartData Simple() => new()
    {
        Labels = { "Mon", "Tue", "Wed", "Thu", "Fri" },
        Datasets =
        {
            new BlazorChartDataset { Label = "Load", Data = SampleData.V(40, 65, 50, 80, 60),
                BackgroundColors = new() { "#36a2eb", "#ff6384", "#4bc0c0", "#ff9f40", "#9966ff" },
                BorderColor = "#36a2eb", Tension = 0.4 }
        }
    };

    private readonly BlazorChartOptions _bottomTitle = new()
    {
        Plugins = new BlazorChartPluginOptions
        {
            Legend = new BlazorChartLegendOptions { Display = false },
            Title = new BlazorChartTitleOptions { Display = true, Text = "Weekly Load\n(arbitrary units)", Position = BlazorChartPosition.Bottom }
        }
    };

    private readonly BlazorChartOptions _indexTooltip = new()
    {
        Plugins = new BlazorChartPluginOptions
        {
            Legend = new BlazorChartLegendOptions { Position = BlazorChartPosition.Bottom },
            Tooltip = new BlazorChartTooltipOptions { Mode = BlazorChartInteractionMode.Index, Position = BlazorChartTooltipPositioner.Average }
        }
    };

    private BlazorChartData TwoSeries() => new()
    {
        Labels = { "Q1", "Q2", "Q3", "Q4" },
        Datasets =
        {
            new BlazorChartDataset { Label = "Revenue", Data = SampleData.V(1200, 1500, 1700, 2100), BorderColor = "#36a2eb", Tension = 0.4 },
            new BlazorChartDataset { Label = "Costs", Data = SampleData.V(800, 950, 1100, 1300), BorderColor = "#ff6384", Tension = 0.4 }
        }
    };
}
