@page "/playground"
@rendermode InteractiveServer

<PageTitle>Playground</PageTitle>

<div class="page-head">
    <h1>Playground</h1>
    <p>Switch chart type and options live against the same dataset. The chart recomputes instantly &mdash; all in C#.</p>
</div>

<div class="controls">
    <label>
        Type
        <select @bind="_type">
            @foreach (var t in Enum.GetValues<BlazorChartType>())
            {
                <option value="@t">@t</option>
            }
        </select>
    </label>
    <label>
        Legend
        <select @bind="_legend">
            <option value="@BlazorChartPosition.Top">Top</option>
            <option value="@BlazorChartPosition.Bottom">Bottom</option>
            <option value="@BlazorChartPosition.Left">Left</option>
            <option value="@BlazorChartPosition.Right">Right</option>
        </select>
    </label>
    <label><input type="checkbox" @bind="_showLegend" /> Show legend</label>
    <label><input type="checkbox" @bind="_fill" /> Fill area</label>
    <label><input type="checkbox" @bind="_stacked" /> Stacked</label>
    <label>
        Tension
        <input type="number" step="0.1" min="0" max="1" @bind="_tension" style="width:70px" />
    </label>
</div>

<div class="card">
    <BlazorChart Config="@BuildConfig()" />
    <CodeBlock Code="@PlaygroundSnippet" />
</div>

@code {
    private const string PlaygroundSnippet = """
        @* One chart, rebuilt from control state via the Config parameter. *@
        <BlazorChart Config="BuildConfig()" />

        @code {
            private BlazorChartType _type = BlazorChartType.Bar;
            private BlazorChartPosition _legend = BlazorChartPosition.Top;
            private bool _showLegend = true;
            private bool _fill = false;
            private bool _stacked = false;
            private double _tension = 0.3;

            private BlazorChartConfig BuildConfig()
            {
                var data = new BlazorChartData
                {
                    Labels = { "Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul" },
                    Datasets =
                    {
                        new BlazorChartDataset { Label = "Alpha", Data = new() { 65, 59, 80, 81, 56, 55, 72 },
                            Tension = _tension, Fill = _fill ? BlazorChartFillMode.Origin : BlazorChartFillMode.None },
                        new BlazorChartDataset { Label = "Beta", Data = new() { 28, 48, 40, 60, 86, 92, 78 },
                            Tension = _tension, Fill = _fill ? BlazorChartFillMode.Origin : BlazorChartFillMode.None }
                    }
                };

                var options = new BlazorChartOptions
                {
                    Plugins = new BlazorChartPluginOptions
                    {
                        Legend = new BlazorChartLegendOptions { Display = _showLegend, Position = _legend }
                    },
                    Scales =
                    {
                        ["x"] = new BlazorChartScaleOptions { Id = "x", Type = BlazorChartScaleType.Category, Stacked = _stacked },
                        ["y"] = new BlazorChartScaleOptions { Id = "y", Type = BlazorChartScaleType.Linear, Stacked = _stacked, BeginAtZero = true }
                    }
                };

                return new BlazorChartConfig(_type, data, options);
            }
        }
        """;

    private BlazorChartType _type = BlazorChartType.Bar;
    private BlazorChartPosition _legend = BlazorChartPosition.Top;
    private bool _showLegend = true;
    private bool _fill = false;
    private bool _stacked = false;
    private double _tension = 0.3;

    private bool IsPointBased => _type is BlazorChartType.Scatter or BlazorChartType.Bubble;

    private BlazorChartConfig BuildConfig()
    {
        var data = IsPointBased ? BuildPointData() : BuildValueData();

        // Scatter/bubble plot points against a numeric x axis; the other types share a category axis.
        var xScaleType = IsPointBased ? BlazorChartScaleType.Linear : BlazorChartScaleType.Category;

        var options = new BlazorChartOptions
        {
            Plugins = new BlazorChartPluginOptions
            {
                Legend = new BlazorChartLegendOptions { Display = _showLegend, Position = _legend }
            },
            Scales =
            {
                ["x"] = new BlazorChartScaleOptions { Id = "x", Type = xScaleType, Stacked = _stacked },
                ["y"] = new BlazorChartScaleOptions { Id = "y", Type = BlazorChartScaleType.Linear, Stacked = _stacked, BeginAtZero = true }
            }
        };

        return new BlazorChartConfig(_type, data, options);
    }

    private BlazorChartData BuildValueData() => new()
    {
        Labels = SampleData.Months.ToList(),
        Datasets =
        {
            new BlazorChartDataset { Label = "Alpha", Data = SampleData.V(65, 59, 80, 81, 56, 55, 72),
                Tension = _tension, Fill = _fill ? BlazorChartFillMode.Origin : BlazorChartFillMode.None },
            new BlazorChartDataset { Label = "Beta", Data = SampleData.V(28, 48, 40, 60, 86, 92, 78),
                Tension = _tension, Fill = _fill ? BlazorChartFillMode.Origin : BlazorChartFillMode.None }
        }
    };

    private BlazorChartData BuildPointData()
    {
        bool bubble = _type is BlazorChartType.Bubble;
        return new BlazorChartData
        {
            Datasets =
            {
                new BlazorChartDataset
                {
                    Label = "Alpha",
                    Points = new()
                    {
                        new(10, 65, bubble ? 12 : null), new(20, 59, bubble ? 6 : null),
                        new(30, 80, bubble ? 18 : null), new(45, 81, bubble ? 9 : null),
                        new(55, 56, bubble ? 14 : null), new(70, 55, bubble ? 7 : null),
                        new(85, 72, bubble ? 16 : null)
                    }
                },
                new BlazorChartDataset
                {
                    Label = "Beta",
                    Points = new()
                    {
                        new(15, 28, bubble ? 8 : null), new(25, 48, bubble ? 15 : null),
                        new(35, 40, bubble ? 6 : null), new(50, 60, bubble ? 20 : null),
                        new(60, 86, bubble ? 10 : null), new(75, 92, bubble ? 13 : null),
                        new(90, 78, bubble ? 7 : null)
                    }
                }
            }
        };
    }
}
