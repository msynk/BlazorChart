@page "/time"

<PageTitle>Time axis</PageTitle>

<div class="page-head">
    <h1>Time axis</h1>
    <p>
        A date/time scale automatically picks a sensible unit (hour, day, week, month, year) for the
        data range and formats tick labels accordingly. Points carry their x as a date.
    </p>
</div>

<div class="grid">
    <div class="card">
        <h3>Daily series (auto unit)</h3>
        <p class="desc">60 days &rarr; weekly ticks</p>
        <BlazorChart Type="BlazorChartType.Line" Data="SampleData.TimeSeries()" Options="@_time" />
    </div>

    <div class="card">
        <h3>Forced month unit + custom format</h3>
        <p class="desc">BlazorChartTimeUnit.Month, custom formatter</p>
        <BlazorChart Type="BlazorChartType.Line" Data="SampleData.TimeSeries()" Options="@_month" />
    </div>
</div>

@code {
    private readonly BlazorChartOptions _time = new()
    {
        Animation = new BlazorChartAnimationOptions { Progressive = true, Duration = 1500 },
        Plugins = new BlazorChartPluginOptions { Legend = new BlazorChartLegendOptions { Display = false } },
        Scales =
        {
            ["x"] = new BlazorChartScaleOptions { Id = "x", Type = BlazorChartScaleType.Time },
            ["y"] = new BlazorChartScaleOptions { Id = "y", Type = BlazorChartScaleType.Linear }
        }
    };

    private readonly BlazorChartOptions _month = new()
    {
        Animation = new BlazorChartAnimationOptions { Progressive = true, Duration = 1500 },
        Plugins = new BlazorChartPluginOptions { Legend = new BlazorChartLegendOptions { Display = false } },
        Scales =
        {
            ["x"] = new BlazorChartScaleOptions
            {
                Id = "x", Type = BlazorChartScaleType.Time, TimeUnit = BlazorChartTimeUnit.Week,
                TimeFormat = d => d.ToString("d MMM")
            },
            ["y"] = new BlazorChartScaleOptions { Id = "y", Type = BlazorChartScaleType.Linear }
        }
    };
}
