@namespace BlazorChart

@switch (Node)
{
    case BlazorChartSvgLine l:
        <line x1="@BlazorChartSvg.N(l.X1)" y1="@BlazorChartSvg.N(l.Y1)" x2="@BlazorChartSvg.N(l.X2)" y2="@BlazorChartSvg.N(l.Y2)"
              stroke="@l.Stroke" stroke-width="@BlazorChartSvg.N(l.StrokeWidth)" opacity="@BlazorChartSvg.N(l.Opacity)"
              stroke-dasharray="@l.Dash" />
        break;

    case BlazorChartSvgRect r:
        <rect x="@BlazorChartSvg.N(r.X)" y="@BlazorChartSvg.N(r.Y)" width="@BlazorChartSvg.N(r.Width)" height="@BlazorChartSvg.N(r.Height)"
              rx="@BlazorChartSvg.N(r.Rx)" fill="@r.Fill" stroke="@r.Stroke" stroke-width="@BlazorChartSvg.N(r.StrokeWidth)"
              opacity="@BlazorChartSvg.N(r.Opacity)" class="@r.CssClass">
            @if (!string.IsNullOrEmpty(r.Title)) { <title>@r.Title</title> }
        </rect>
        break;

    case BlazorChartSvgCircle c:
        <circle cx="@BlazorChartSvg.N(c.Cx)" cy="@BlazorChartSvg.N(c.Cy)" r="@BlazorChartSvg.N(c.R)" fill="@c.Fill"
                stroke="@c.Stroke" stroke-width="@BlazorChartSvg.N(c.StrokeWidth)" opacity="@BlazorChartSvg.N(c.Opacity)" class="@c.CssClass" />
        break;

    case BlazorChartSvgPath p:
        <path d="@p.D" fill="@p.Fill" stroke="@p.Stroke" stroke-width="@BlazorChartSvg.N(p.StrokeWidth)"
              stroke-dasharray="@p.Dash" stroke-linecap="@p.LineCap" stroke-linejoin="@p.LineJoin"
              opacity="@BlazorChartSvg.N(p.Opacity)" class="@(p.AnimateDraw ? "bc-draw" : p.AnimateFade ? "bc-fade" : p.CssClass)"
              pathLength="@(p.AnimateDraw ? "1" : null)" />
        break;

    case BlazorChartSvgPolygon poly:
        @if (poly.Closed)
        {
            <polygon points="@PolyPoints(poly)" fill="@poly.Fill" stroke="@poly.Stroke"
                     stroke-width="@BlazorChartSvg.N(poly.StrokeWidth)" stroke-linejoin="round" opacity="@BlazorChartSvg.N(poly.Opacity)" />
        }
        else
        {
            <polyline points="@PolyPoints(poly)" fill="none" stroke="@poly.Stroke"
                      stroke-width="@BlazorChartSvg.N(poly.StrokeWidth)" opacity="@BlazorChartSvg.N(poly.Opacity)" />
        }
        break;

    case BlazorChartSvgText t:
        @((MarkupString)BuildText(t))
        break;
}

@code {
    [Parameter, EditorRequired] public BlazorChartSvgNode Node { get; set; } = default!;

    private static string PolyPoints(BlazorChartSvgPolygon p) =>
        string.Join(" ", p.Points.Select(pt => $"{BlazorChartSvg.N(pt.X)},{BlazorChartSvg.N(pt.Y)}"));

    private static string BuildText(BlazorChartSvgText t)
    {
        string transform = t.Rotation != 0
            ? $" transform=\"rotate({BlazorChartSvg.N(t.Rotation)} {BlazorChartSvg.N(t.X)} {BlazorChartSvg.N(t.Y)})\""
            : "";
        string content = System.Net.WebUtility.HtmlEncode(t.Text);
        return $"<text x=\"{BlazorChartSvg.N(t.X)}\" y=\"{BlazorChartSvg.N(t.Y)}\" fill=\"{t.Fill}\" " +
               $"font-family=\"{System.Net.WebUtility.HtmlEncode(t.FontFamily)}\" font-size=\"{BlazorChartSvg.N(t.FontSize)}\" " +
               $"font-weight=\"{t.FontWeight}\" font-style=\"{t.FontStyle}\" text-anchor=\"{t.Anchor}\" " +
               $"dominant-baseline=\"{t.Baseline}\" opacity=\"{BlazorChartSvg.N(t.Opacity)}\"{transform}>{content}</text>";
    }
}
