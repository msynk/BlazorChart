@using BlazorChart.Rendering
@namespace BlazorChart.Components

@switch (Node)
{
    case SvgLine l:
        <line x1="@Svg.N(l.X1)" y1="@Svg.N(l.Y1)" x2="@Svg.N(l.X2)" y2="@Svg.N(l.Y2)"
              stroke="@l.Stroke" stroke-width="@Svg.N(l.StrokeWidth)" opacity="@Svg.N(l.Opacity)"
              stroke-dasharray="@l.Dash" />
        break;

    case SvgRect r:
        <rect x="@Svg.N(r.X)" y="@Svg.N(r.Y)" width="@Svg.N(r.Width)" height="@Svg.N(r.Height)"
              rx="@Svg.N(r.Rx)" fill="@r.Fill" stroke="@r.Stroke" stroke-width="@Svg.N(r.StrokeWidth)"
              opacity="@Svg.N(r.Opacity)" class="@r.CssClass">
            @if (!string.IsNullOrEmpty(r.Title)) { <title>@r.Title</title> }
        </rect>
        break;

    case SvgCircle c:
        <circle cx="@Svg.N(c.Cx)" cy="@Svg.N(c.Cy)" r="@Svg.N(c.R)" fill="@c.Fill"
                stroke="@c.Stroke" stroke-width="@Svg.N(c.StrokeWidth)" opacity="@Svg.N(c.Opacity)" class="@c.CssClass" />
        break;

    case SvgPath p:
        <path d="@p.D" fill="@p.Fill" stroke="@p.Stroke" stroke-width="@Svg.N(p.StrokeWidth)"
              stroke-dasharray="@p.Dash" stroke-linecap="@p.LineCap" stroke-linejoin="@p.LineJoin"
              opacity="@Svg.N(p.Opacity)" class="@(p.AnimateDraw ? "bc-draw" : p.AnimateFade ? "bc-fade" : p.CssClass)"
              pathLength="@(p.AnimateDraw ? "1" : null)" />
        break;

    case SvgPolygon poly:
        @if (poly.Closed)
        {
            <polygon points="@PolyPoints(poly)" fill="@poly.Fill" stroke="@poly.Stroke"
                     stroke-width="@Svg.N(poly.StrokeWidth)" stroke-linejoin="round" opacity="@Svg.N(poly.Opacity)" />
        }
        else
        {
            <polyline points="@PolyPoints(poly)" fill="none" stroke="@poly.Stroke"
                      stroke-width="@Svg.N(poly.StrokeWidth)" opacity="@Svg.N(poly.Opacity)" />
        }
        break;

    case SvgText t:
        @((MarkupString)BuildText(t))
        break;
}

@code {
    [Parameter, EditorRequired] public SvgNode Node { get; set; } = default!;

    private static string PolyPoints(SvgPolygon p) =>
        string.Join(" ", p.Points.Select(pt => $"{Svg.N(pt.X)},{Svg.N(pt.Y)}"));

    private static string BuildText(SvgText t)
    {
        string transform = t.Rotation != 0
            ? $" transform=\"rotate({Svg.N(t.Rotation)} {Svg.N(t.X)} {Svg.N(t.Y)})\""
            : "";
        string content = System.Net.WebUtility.HtmlEncode(t.Text);
        return $"<text x=\"{Svg.N(t.X)}\" y=\"{Svg.N(t.Y)}\" fill=\"{t.Fill}\" " +
               $"font-family=\"{System.Net.WebUtility.HtmlEncode(t.FontFamily)}\" font-size=\"{Svg.N(t.FontSize)}\" " +
               $"font-weight=\"{t.FontWeight}\" font-style=\"{t.FontStyle}\" text-anchor=\"{t.Anchor}\" " +
               $"dominant-baseline=\"{t.Baseline}\" opacity=\"{Svg.N(t.Opacity)}\"{transform}>{content}</text>";
    }
}
